{
  "name": "typos.ai",
  "version": "1.1.0",
  "description": "CLI tool to run fix after typos",
  "main": "lib/llm/decide.js",
  "type": "module",
  "scripts": {
    "test": "madrun test",
    "watch:test": "madrun watch:test",
    "lint": "madrun lint",
    "fresh:lint": "madrun fresh:lint",
    "lint:fresh": "madrun lint:fresh",
    "fix:lint": "madrun fix:lint",
    "coverage": "madrun coverage",
    "report": "madrun report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderaiser/typos.ai.git"
  },
  "bin": {
    "typos.ai": "bin/typos.js"
  },
  "keywords": [
    "typos",
    "scripts",
    "package",
    "npm",
    "npm run",
    "npm-scripts",
    "tool",
    "cli",
    "command",
    "task",
    "parallel",
    "serial",
    "run",
    "commandline"
  ],
  "author": "coderaiser <mnemonic.enemy@gmail.com> (http://coderaiser.github.io/)",
  "bugs": {
    "url": "https://github.com/coderaiser/typos.ai/issues"
  },
  "homepage": "https://github.com/coderaiser/typos.ai",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "redstd": "^1.0.2",
    "try-catch": "^4.0.1",
    "try-to-catch": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@putout/formatter-json": "^3.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-putout": "^31.0.0",
    "madrun": "^13.0.2",
    "nodemon": "^3.0.1",
    "redlint": "^6.0.0",
    "superc8": "^12.2.4",
    "supertape": "^13.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
